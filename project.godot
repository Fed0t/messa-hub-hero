; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MessaHub Hero"
run/main_scene="res://world.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SimpleGrass="*res://addons/simplegrasstextured/singleton.tscn"
GameManager="*res://autoload/game_manager.gd"
InputManager="*res://autoload/input_manager.gd"
SelectionManager="*res://autoload/selection_manager.gd"
MissionManager="*res://autoload/mission_manager.gd"
CursorManager="*res://autoload/cursor_manager.gd"

[input]

